# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
.env

# API keys — never commit these
.env.local
*.env

# Agent runtime output — generated on each run, not source
output/

# Auto-fix scripts generated by the platform agent
module8/fixes/

# macOS metadata
.DS_Store
**/.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Jupyter (if used for exploration)
.ipynb_checkpoints/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Distribution / packaging (shouldn't exist here, but just in case)
dist/
build/
*.egg-info/
